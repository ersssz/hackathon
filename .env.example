# =============================================================================
# ZeroTrust-AI — runtime configuration
# =============================================================================
# ZeroTrust-AI uses a SINGLE OpenAI-compatible API endpoint. You can point it
# at any provider that speaks the OpenAI /v1/chat/completions wire format.

# --- API credentials -----------------------------------------------------
# Your bearer token for the endpoint below.
LLM_API_KEY=your_api_key_here

# Endpoint root (/v1). Uncomment the line for the provider you want to use,
# or paste a custom URL (local vLLM, Ollama, corporate proxy, etc).
LLM_BASE_URL=https://api.fireworks.ai/inference/v1
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_BASE_URL=https://api.deepinfra.com/v1/openai
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_BASE_URL=http://localhost:11434/v1      # Ollama / LM Studio

# --- Back-compat (legacy; still read if LLM_API_KEY is missing) ----------
# FIREWORKS_API_KEY=your_fireworks_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Fireworks.ai API key (get from https://fireworks.ai)
FIREWORKS_API_KEY=your_key_here

# Optional: OpenAI-compatible providers
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Default target model (model under test)
DEFAULT_TARGET_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct

# Judge model (evaluates attack success)
DEFAULT_JUDGE_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
